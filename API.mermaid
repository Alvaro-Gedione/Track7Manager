erDiagram
    %% Classes Existentes (Mantidas)
    acl_profiles {
        BigInt id PK
        String name
        String slug
        Json default_permissions
    }
    
    acl_users {
        BigInt id PK
        BigInt acl_profile_id
        BigInt user_id UK
        Json permissions
        Boolean active
    }
    
    alerts {
        BigInt id PK
        String title
        String message
        String location
        DateTime created_at
        DateTime updated_at
    }
    
    alerted {
        BigInt id PK
        BigInt alert_id FK
        BigInt user_id FK
        Int read
    }
    
    asked_questions {
        String id PK
        String title
        String answer
        DateTime created_at
        DateTime updated_at
    }
    
    assets {
        BigInt asset_id PK
